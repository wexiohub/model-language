{
  "name": "model-language",
  "version": "1.0.0",
  "description": "A typed, safe template language for AI-agent prompts. Variables, conditions, loops and filters that render to clean text against live data, type-checked at edit time — never crashes, never leaks syntax. One WebAssembly engine, eight languages.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "bench": "vitest bench --run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "example": "tsx examples/basic.ts",
    "example:run": "tsx examples/run.ts",
    "wasm:build": "node wasm/build.mjs"
  },
  "keywords": [
    "prompt",
    "prompt-engineering",
    "prompt-template",
    "ai",
    "ai-agent",
    "llm",
    "agent",
    "template",
    "template-engine",
    "template-language",
    "dsl",
    "typed",
    "type-safe",
    "wasm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wexiohub/model-language.git"
  },
  "bugs": { "url": "https://github.com/wexiohub/model-language/issues" },
  "homepage": "https://github.com/wexiohub/model-language#readme",
  "publishConfig": { "access": "public" },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.28.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
